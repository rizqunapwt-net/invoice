# Laravel Security Hardening Configuration
# Add to .env file

# Application security
APP_CIPHER=AES-256-CBC
APP_URL=https://invoice.domain.com

# Force HTTPS in production
FORCE_HTTPS=true

# Security headers
ENABLE_SECURITY_HEADERS=true
X_FRAME_OPTIONS=SAMEORIGIN
X_CONTENT_TYPE_OPTIONS=nosniff
X_XSS_PROTECTION=1

# Session security
SESSION_SECURE_COOKIES=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

# Database security
DB_HOST=db-invoice
DB_USERNAME=u9443309_invoice
DB_PASSWORD=use_strong_password_here
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Authentication
AUTH_PASSWORD_RESET_TIMEOUT=60
BCRYPT_ROUNDS=12

# API security
RATE_LIMIT=60
THROTTLE_MINUTES=1

# CORS (if needed)
CORS_ALLOWED_ORIGINS=https://invoice.domain.com
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# Disable debug in production
APP_DEBUG=false
APP_ENV=production

# Encryption key (generate with: php artisan key:generate)
APP_KEY=base64:your_generated_key_here

# Log configuration
LOG_CHANNEL=stack
LOG_LEVEL=critical
